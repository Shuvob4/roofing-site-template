---
/**
 * TestimonialsCarousel — Section displaying customer testimonials in a grid.
 * Reads from the testimonials content collection.
 * Prioritizes featured testimonials first, then by definition order.
 * Renders nothing if there are zero entries.
 *
 * Validates: Requirements 7.1, 7.2, 7.3, 7.4, 7.5
 */
import Card from '@components/ui/Card.astro';
import StarRating from '@components/ui/StarRating.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

interface Props {
  limit?: number;
}

const { limit = 6 } = Astro.props;

// Fetch all testimonials from collection
const allTestimonials = await getCollection('testimonials');

// Sort: featured first, then by original definition order
const sorted = [...allTestimonials].sort((a, b) => {
  if (a.data.featured && !b.data.featured) return -1;
  if (!a.data.featured && b.data.featured) return 1;
  return 0;
});

// Apply limit
const limited = sorted.slice(0, limit);

// Render markdown body for each testimonial
const rendered = await Promise.all(
  limited.map(async (t) => {
    const { Content } = await render(t);
    return { ...t, Content };
  })
);
---

{rendered.length > 0 && (
  <section class="testimonials" aria-label="Customer Testimonials">
    <div class="testimonials__container">
      <h2 class="testimonials__heading">What Our Customers Say</h2>
      <div class="testimonials__grid">
        {rendered.map(({ data, Content }) => (
          <Card class="testimonial-card">
            <div class="testimonial-card__stars">
              <StarRating rating={data.rating} />
            </div>
            <div class="testimonial-card__body">
              <Content />
            </div>
            <div class="testimonial-card__footer">
              <span class="testimonial-card__name">{data.customerName}</span>
              {data.location && (
                <span class="testimonial-card__location">{data.location}</span>
              )}
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .testimonials {
    padding: 4rem 1.5rem;
  }

  .testimonials__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 3vw, var(--font-size-large, 2rem));
    text-align: center;
    margin: 0 0 2.5rem;
    color: var(--color-text);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* Desktop: 2 columns */
  @media (min-width: 768px) {
    .testimonials__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .testimonial-card__stars {
    margin-bottom: 0.75rem;
  }

  .testimonial-card__body {
    flex: 1;
    font-family: var(--font-body);
    font-size: var(--font-size-base, 1rem);
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .testimonial-card__body :global(p) {
    margin: 0;
  }

  .testimonial-card__footer {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .testimonial-card__name {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text);
  }

  .testimonial-card__location {
    font-family: var(--font-body);
    font-size: var(--font-size-small, 0.875rem);
    color: var(--color-text);
    opacity: 0.7;
  }
</style>
