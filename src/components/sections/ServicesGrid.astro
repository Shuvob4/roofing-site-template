---
/**
 * ServicesGrid — Card grid section displaying services grouped by category.
 * Reads from the services content collection, groups by category (residential/commercial),
 * sorts by order field, and renders each service as a Card with image/icon fallback.
 *
 * Props:
 *   - limit (optional): Maximum number of services to display (for homepage subset)
 *
 * Validates: Requirements 4.1, 4.2, 4.3, 4.4, 4.5, 4.6
 */
import Card from '@components/ui/Card.astro';
import { getCollection } from 'astro:content';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;

// Fetch all services and sort by order
const allServices = await getCollection('services');
const sortedServices = allServices.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

// Apply limit if specified (for homepage usage)
const services = limit ? sortedServices.slice(0, limit) : sortedServices;

// Group by category
const residential = services.filter((s) => s.data.category === 'residential');
const commercial = services.filter((s) => s.data.category === 'commercial');

// Icon fallback SVG map for common service icons
const iconMap: Record<string, string> = {
  wrench: '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>',
  home: '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>',
  building: '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2" ry="2"></rect><path d="M9 22v-4h6v4"></path><path d="M8 6h.01"></path><path d="M16 6h.01"></path><path d="M12 6h.01"></path><path d="M12 10h.01"></path><path d="M12 14h.01"></path><path d="M16 10h.01"></path><path d="M16 14h.01"></path><path d="M8 10h.01"></path><path d="M8 14h.01"></path></svg>',
  'alert-triangle': '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>',
  'shield-check': '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>',
};

// Default fallback icon (generic roofing/tool icon)
const defaultIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>';

function getIconSvg(iconName?: string): string {
  if (!iconName) return defaultIcon;
  return iconMap[iconName] || defaultIcon;
}
---

<section class="services-grid" aria-label="Our Services">
  {residential.length > 0 && (
    <div class="services-grid__group">
      <h2 class="services-grid__category-heading">Residential</h2>
      <div class="services-grid__cards">
        {residential.map((service) => (
          <Card class="services-grid__card">
            <div class="services-grid__card-image">
              {service.data.image ? (
                <img
                  src={service.data.image}
                  alt={service.data.title}
                  loading="lazy"
                  width="400"
                  height="250"
                />
              ) : (
                <div class="services-grid__card-icon" aria-hidden="true">
                  <Fragment set:html={getIconSvg(service.data.icon)} />
                </div>
              )}
            </div>
            <div class="services-grid__card-body">
              <h3 class="services-grid__card-title">{service.data.title}</h3>
              <p class="services-grid__card-description">{service.data.shortDescription}</p>
              <a href={`/services/${service.id}`} class="services-grid__card-link">
                Learn More
                <span class="visually-hidden"> about {service.data.title}</span>
              </a>
            </div>
          </Card>
        ))}
      </div>
    </div>
  )}

  {commercial.length > 0 && (
    <div class="services-grid__group">
      <h2 class="services-grid__category-heading">Commercial</h2>
      <div class="services-grid__cards">
        {commercial.map((service) => (
          <Card class="services-grid__card">
            <div class="services-grid__card-image">
              {service.data.image ? (
                <img
                  src={service.data.image}
                  alt={service.data.title}
                  loading="lazy"
                  width="400"
                  height="250"
                />
              ) : (
                <div class="services-grid__card-icon" aria-hidden="true">
                  <Fragment set:html={getIconSvg(service.data.icon)} />
                </div>
              )}
            </div>
            <div class="services-grid__card-body">
              <h3 class="services-grid__card-title">{service.data.title}</h3>
              <p class="services-grid__card-description">{service.data.shortDescription}</p>
              <a href={`/services/${service.id}`} class="services-grid__card-link">
                Learn More
                <span class="visually-hidden"> about {service.data.title}</span>
              </a>
            </div>
          </Card>
        ))}
      </div>
    </div>
  )}
</section>

<style>
  .services-grid {
    padding: 4rem 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .services-grid__group {
    margin-bottom: 3rem;
  }

  .services-grid__group:last-child {
    margin-bottom: 0;
  }

  .services-grid__category-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-large, 1.25rem);
    color: var(--color-text);
    margin: 0 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-accent);
  }

  .services-grid__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  /* Tablet: 2 columns */
  @media (min-width: 768px) {
    .services-grid__cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Desktop: 3 columns */
  @media (min-width: 1024px) {
    .services-grid__cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .services-grid__card {
    display: flex;
    flex-direction: column;
    padding: 0;
    overflow: hidden;
  }

  .services-grid__card-image {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background-color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .services-grid__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .services-grid__card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .services-grid__card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .services-grid__card-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-base, 1rem);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .services-grid__card-description {
    font-family: var(--font-body);
    font-size: var(--font-size-small, 0.875rem);
    color: var(--color-text);
    opacity: 0.85;
    margin: 0 0 1rem;
    flex: 1;
    line-height: 1.5;
  }

  .services-grid__card-link {
    display: inline-flex;
    align-items: center;
    color: var(--color-accent);
    font-family: var(--font-body);
    font-size: var(--font-size-small, 0.875rem);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .services-grid__card-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  .services-grid__card-link:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .services-grid__card-link {
      transition: none;
    }
  }
</style>
