---
/**
 * Button — Accessible button/link component with variant styling.
 * Renders as <a> when href is provided, <button> otherwise.
 * All variants meet minimum 44x44px touch target size.
 */
interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'emergency';
  href?: string;
  class?: string;
  type?: 'button' | 'submit' | 'reset';
}

const { variant = 'primary', href, class: className, type = 'button' } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['btn', `btn--${variant}`, className]}
  {...href ? { href } : { type }}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: var(--border-radius);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--font-size-base);
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    line-height: 1.2;
  }

  .btn:hover {
    opacity: 0.85;
  }

  .btn:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* Primary variant */
  .btn--primary {
    background-color: var(--color-accent);
    color: var(--color-on-accent, #fff);
  }

  /* Accent variant (alias for primary styling) */
  .btn--accent {
    background-color: var(--color-accent);
    color: var(--color-on-accent, #fff);
  }

  /* Secondary variant */
  .btn--secondary {
    background-color: var(--color-secondary);
    color: var(--color-text);
  }

  /* Emergency variant */
  .btn--emergency {
    background-color: var(--color-emergency);
    color: var(--color-on-emergency, #fff);
  }

  @media (prefers-reduced-motion: reduce) {
    .btn {
      transition: none;
    }
  }
</style>
