---
/**
 * StarRating — Accessible star rating display component.
 * Renders filled and empty stars using inline SVG.
 * Uses CSS custom properties for theming.
 */
interface Props {
  rating: number;
  max?: number;
}

const { rating, max = 5 } = Astro.props;

// Clamp rating to valid range
const clampedRating = Math.max(0, Math.min(rating, max));
const filledStars = Math.round(clampedRating);
const emptyStars = max - filledStars;
---

<div class="star-rating" role="img" aria-label={`${clampedRating} out of ${max} stars`}>
  {Array.from({ length: filledStars }).map(() => (
    <svg class="star star--filled" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
    </svg>
  ))}
  {Array.from({ length: emptyStars }).map(() => (
    <svg class="star star--empty" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
    </svg>
  ))}
</div>

<style>
  .star-rating {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
  }

  .star {
    flex-shrink: 0;
  }

  .star--filled {
    color: var(--color-accent);
  }

  .star--empty {
    color: var(--color-secondary);
  }
</style>
