---
/**
 * QuoteForm — Quote request form with file upload, roof type selection,
 * and full spam/consent protection.
 * Reads config from forms.yaml and site config for business name.
 *
 * Validates: Requirements 13.1, 13.2, 13.3, 13.4, 13.5, 13.6, 13.7, 13.8, 13.9, 13.10, 33.1, 33.4, 34.1, 34.2
 */
import FormField from './FormField.astro';
import ConsentCheckbox from './ConsentCheckbox.astro';
import HoneypotField from './HoneypotField.astro';
import TurnstileWidget from './TurnstileWidget.astro';
import Button from '@components/ui/Button.astro';
import { getEntry } from 'astro:content';

const formsEntry = await getEntry('forms', 'forms');
const formsConfig = formsEntry.data;
const siteEntry = await getEntry('site', 'config');
const siteConfig = siteEntry.data;

const { roofTypes, maxFiles, maxFileSizeMB } = formsConfig.quoteForm;
const { workerEndpoint } = formsConfig.formBackend;
const { turnstileSiteKey, honeypotFieldName, turnstileEnabled } = formsConfig.spam;

const consentLabel = `I consent to being contacted by ${siteConfig.businessName} via email, phone, or SMS regarding my inquiry`;
const maxFileSizeBytes = maxFileSizeMB * 1024 * 1024;
const acceptedFileTypes = '.jpg,.jpeg,.png,.heic';
const supportsFiles = maxFiles > 0;
---

<form
  id="quote-form"
  class="quote-form"
  novalidate
  data-worker-endpoint={workerEndpoint}
  data-turnstile-site-key={turnstileSiteKey}
  data-honeypot-field={honeypotFieldName}
  data-max-file-size={String(maxFileSizeBytes)}
  data-max-files={String(maxFiles)}
  data-accepted-types="image/jpeg,image/png,image/heic"
  data-consent-text={consentLabel}
>
  <FormField
    label="Roof Type"
    name="roof_type"
    type="select"
    required={true}
    options={roofTypes}
    placeholder="Select your roof type"
  />

  <FormField
    label="Issue Description"
    name="issue_description"
    type="textarea"
    rows={5}
    maxLength={2000}
    placeholder="Describe the issue with your roof..."
  />

  {supportsFiles && (
    <div class="form-field">
      <label class="form-field__label" for="field-photos">
        Photo Upload
        <span class="form-field__hint">(Max {maxFiles} files, .jpg/.png/.heic)</span>
      </label>
      <input
        class="form-field__input form-field__file"
        id="field-photos"
        name="photos"
        type="file"
        accept={acceptedFileTypes}
        multiple
      />
      <span class="form-field__error" id="field-photos-error" role="alert" aria-live="assertive"></span>
    </div>
  )}

  <FormField
    label="Your Name"
    name="customer_name"
    type="text"
    required={true}
    maxLength={100}
    placeholder="Full name"
  />

  <FormField
    label="Phone"
    name="phone"
    type="tel"
    required={true}
    placeholder="Your phone number"
  />

  <FormField
    label="Email"
    name="email"
    type="email"
    required={true}
    placeholder="you@example.com"
  />

  <ConsentCheckbox businessName={siteConfig.businessName} />

  <HoneypotField fieldName={honeypotFieldName} />

  <TurnstileWidget siteKey={turnstileSiteKey} enabled={turnstileEnabled} />

  <Button type="submit" variant="primary">Request a Quote</Button>

  <div class="quote-form__messages" aria-live="polite"></div>
</form>

<script>
  import { initFormHandler } from '@scripts/form-handler';

  function init() {
    const form = document.querySelector<HTMLFormElement>('#quote-form');
    if (!form) return;

    const workerEndpoint = form.dataset.workerEndpoint || '';
    const turnstileSiteKey = form.dataset.turnstileSiteKey || null;
    const honeypotFieldName = form.dataset.honeypotField || 'website_url';
    const maxFileSize = parseInt(form.dataset.maxFileSize || '0', 10);
    const maxFiles = parseInt(form.dataset.maxFiles || '0', 10);
    const acceptedTypes = (form.dataset.acceptedTypes || '').split(',').filter(Boolean);
    const consentText = form.dataset.consentText || '';

    initFormHandler('#quote-form', {
      workerEndpoint,
      turnstileSiteKey,
      honeypotFieldName,
      maxFileSize,
      maxFiles,
      acceptedTypes,
      consentText,
    });
  }

  init();
</script>

<style>
  .quote-form {
    max-width: 40rem;
  }

  .quote-form__messages:empty {
    display: none;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    margin-bottom: 1rem;
  }

  .form-field__label {
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    font-weight: 500;
    color: var(--color-text);
  }

  .form-field__hint {
    font-weight: 400;
    font-size: 0.875rem;
    opacity: 0.7;
    margin-left: 0.5rem;
  }

  .form-field__input {
    min-height: 44px;
    padding: 0.625rem 0.75rem;
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    color: var(--color-text);
    background-color: var(--color-background);
    border: 2px solid var(--color-secondary);
    border-radius: var(--border-radius);
    width: 100%;
  }

  .form-field__file {
    padding: 0.5rem;
    cursor: pointer;
  }

  .form-field__error {
    font-size: var(--font-size-small, 0.875rem);
    color: var(--color-emergency, #ff4444);
    min-height: 1.25rem;
    display: block;
  }

  .form-field__error:empty {
    display: none;
  }
</style>
