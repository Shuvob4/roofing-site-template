---
/**
 * Assessment Page — Roof condition self-assessment checklist.
 * Uses getStaticPaths() to conditionally generate this route.
 * If module disabled: page is NOT generated at build time (no orphan URL).
 *
 * Validates: Requirements 20.1, 20.2, 20.3, 20.4, 20.5, 20.6
 */
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const modulesEntry = await getEntry('modules', 'modules');
  const isEnabled = modulesEntry?.data?.assessment ?? false;
  if (!isEnabled) return [];
  const entries = await getCollection('assessment');
  if (entries.length === 0) return [];
  return [{ params: { rest: undefined } }];
}

const entries = await getCollection('assessment');
const assessmentData = entries[0].data;
---

<PageLayout title="Roof Assessment" description="Use our checklist to assess the condition of your roof and determine if you need professional help.">
  <section class="assessment-page" aria-label="Roof assessment checklist">
    <div class="assessment-page__header">
      <h1 class="assessment-page__title">Roof Assessment Checklist</h1>
      <p class="assessment-page__subtitle">
        Use this checklist to evaluate the condition of your roof. If you notice any of these issues, it may be time for a professional inspection.
      </p>
    </div>
    <ul class="assessment-page__checklist" role="list">
      {assessmentData.checklistItems.map((item, index) => (
        <li class="checklist-item">
          <input
            type="checkbox"
            class="checklist-item__checkbox"
            id={`check-${index}`}
            aria-label={item.label}
          />
          <label class="checklist-item__content" for={`check-${index}`}>
            <span class="checklist-item__label">{item.label}</span>
            {item.description && (
              <p class="checklist-item__description">{item.description}</p>
            )}
          </label>
        </li>
      ))}
    </ul>
    <div class="assessment-page__cta">
      <a href={assessmentData.ctaLink} class="assessment-page__cta-button">
        {assessmentData.ctaButtonText}
      </a>
    </div>
  </section>
</PageLayout>

<style>
  .assessment-page {
    min-height: 60vh;
    padding: 3rem 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .assessment-page__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .assessment-page__title {
    font-family: var(--font-heading, sans-serif);
    font-size: var(--font-size-display, 2.5rem);
    font-weight: 700;
    color: var(--color-text, #fff);
    margin: 0 0 0.75rem;
  }

  .assessment-page__subtitle {
    font-family: var(--font-body, sans-serif);
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text, #fff);
    opacity: 0.8;
    margin: 0;
    line-height: 1.6;
  }

  .assessment-page__checklist {
    list-style: none;
    padding: 0;
    margin: 0 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .checklist-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
    background: color-mix(in srgb, var(--color-background, #1a1a2e) 80%, var(--color-primary, #4a90d9) 20%);
    border-radius: var(--border-radius, 0.5rem);
    cursor: pointer;
    transition: background 0.15s ease;
  }

  .checklist-item:hover {
    background: color-mix(in srgb, var(--color-background, #1a1a2e) 70%, var(--color-primary, #4a90d9) 30%);
  }

  .checklist-item__checkbox {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    margin-top: 0.15rem;
    accent-color: var(--color-accent, #e63946);
    cursor: pointer;
  }

  .checklist-item__content {
    flex: 1;
    cursor: pointer;
  }

  .checklist-item__label {
    font-family: var(--font-heading, sans-serif);
    font-size: var(--font-size-large, 1.25rem);
    font-weight: 600;
    color: var(--color-text, #fff);
    display: block;
    margin-bottom: 0.25rem;
  }

  .checklist-item__description {
    font-family: var(--font-body, sans-serif);
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text, #fff);
    opacity: 0.8;
    margin: 0;
    line-height: 1.5;
  }

  .assessment-page__cta {
    text-align: center;
  }

  .assessment-page__cta-button {
    display: inline-block;
    padding: 1rem 2.5rem;
    background: var(--color-accent, #e63946);
    color: var(--color-on-accent, #fff);
    font-family: var(--font-heading, sans-serif);
    font-size: var(--font-size-base, 1rem);
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--border-radius, 0.5rem);
    min-height: 44px;
    transition: opacity 0.2s ease;
  }

  .assessment-page__cta-button:hover {
    opacity: 0.9;
  }

  .assessment-page__cta-button:focus-visible {
    outline: 2px solid var(--color-accent, #f5a623);
    outline-offset: 2px;
  }
</style>
