---
/**
 * Service Detail Page — Dynamic page for each service entry.
 * Uses getCollection('services') for getStaticPaths().
 * Renders full Markdown body content, service image, and category badge.
 *
 * Validates: Requirements 4.2, 4.5
 */
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

const { service } = Astro.props;
const { title, shortDescription, image, icon, category } = service.data;
const { Content } = await render(service);

// Category labels
const categoryLabels: Record<string, string> = {
  residential: 'Residential',
  commercial: 'Commercial',
};
---

<PageLayout title={title} description={shortDescription}>
  <article class="service-detail">
    <div class="service-detail__container">
      {/* Service image or fallback */}
      {image && (
        <div class="service-detail__image-wrapper">
          <img
            src={image}
            alt={title}
            class="service-detail__image"
            width="800"
            height="450"
          />
        </div>
      )}

      <div class="service-detail__content">
        {/* Category badge */}
        <span class="service-detail__badge" data-category={category}>
          {categoryLabels[category] || category}
        </span>

        <h1 class="service-detail__title">{title}</h1>
        <p class="service-detail__short-description">{shortDescription}</p>

        {/* Full Markdown content rendered to HTML */}
        <div class="service-detail__body prose">
          <Content />
        </div>

        <div class="service-detail__actions">
          <a href="/quote" class="service-detail__cta">Get a Free Quote</a>
          <a href="/services" class="service-detail__back">← Back to All Services</a>
        </div>
      </div>
    </div>
  </article>
</PageLayout>

<style>
  .service-detail {
    padding: 3rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .service-detail__container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .service-detail__image-wrapper {
    width: 100%;
    border-radius: var(--border-radius);
    overflow: hidden;
  }

  .service-detail__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .service-detail__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .service-detail__badge {
    display: inline-block;
    width: fit-content;
    padding: 0.25rem 0.75rem;
    border-radius: var(--border-radius);
    font-family: var(--font-body);
    font-size: var(--font-size-small, 0.875rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: var(--color-accent);
    color: var(--color-on-accent, #fff);
  }

  .service-detail__badge[data-category="commercial"] {
    background-color: var(--color-primary);
    color: var(--color-text);
    border: 1px solid var(--color-accent);
  }

  .service-detail__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, var(--font-size-display, 3.5rem));
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.15;
  }

  .service-detail__short-description {
    font-family: var(--font-body);
    font-size: var(--font-size-large, 1.25rem);
    color: var(--color-text);
    opacity: 0.85;
    margin: 0;
    line-height: 1.5;
  }

  .service-detail__body {
    font-family: var(--font-body);
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text);
    line-height: 1.7;
    margin-top: 1rem;
  }

  .service-detail__body :global(p) {
    margin: 0 0 1rem;
  }

  .service-detail__body :global(ul),
  .service-detail__body :global(ol) {
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .service-detail__body :global(li) {
    margin-bottom: 0.5rem;
  }

  .service-detail__body :global(h2),
  .service-detail__body :global(h3) {
    font-family: var(--font-heading);
    color: var(--color-text);
    margin: 1.5rem 0 0.75rem;
  }

  .service-detail__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-secondary);
  }

  .service-detail__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    padding: 0.75rem 1.5rem;
    background-color: var(--color-accent);
    color: var(--color-on-accent, #fff);
    border-radius: var(--border-radius);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--font-size-base, 1rem);
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .service-detail__cta:hover {
    opacity: 0.85;
  }

  .service-detail__cta:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
  }

  .service-detail__back {
    font-family: var(--font-body);
    font-size: var(--font-size-small, 0.875rem);
    color: var(--color-text);
    opacity: 0.7;
    text-decoration: none;
  }

  .service-detail__back:hover {
    opacity: 1;
    text-decoration: underline;
  }

  .service-detail__back:focus-visible {
    outline: 3px solid var(--color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .service-detail__cta {
      transition: none;
    }
  }
</style>
