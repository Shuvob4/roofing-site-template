---
/**
 * Gallery Page — Showcases completed roofing projects.
 * Displays a grid of before/after comparisons and single project photos.
 * Uses PageLayout for consistent site-wide structure.
 *
 * Validates: Requirements 6.1, 6.2, 6.3, 6.4, 6.5, 6.6, 6.7
 */
import PageLayout from '@layouts/PageLayout.astro';
import GalleryGrid from '@components/gallery/GalleryGrid.astro';
---

<PageLayout title="Project Gallery" description="Browse our completed roofing projects with before and after photos showcasing our quality workmanship.">
  <section class="gallery-page">
    <div class="gallery-page__header">
      <h1 class="gallery-page__title">Project Gallery</h1>
      <p class="gallery-page__subtitle">
        Browse our completed projects to see the quality of our workmanship.
      </p>
    </div>
    <GalleryGrid emptyMessage="No projects to display yet. Check back soon for our latest work!" />
  </section>
</PageLayout>

<style>
  .gallery-page {
    min-height: 60vh;
  }

  .gallery-page__header {
    text-align: center;
    padding: 3rem 1.5rem 0;
    max-width: 800px;
    margin: 0 auto;
  }

  .gallery-page__title {
    font-family: var(--font-heading, sans-serif);
    font-size: var(--font-size-display, 2.5rem);
    font-weight: 700;
    color: var(--color-text, #fff);
    margin: 0 0 0.75rem;
  }

  .gallery-page__subtitle {
    font-family: var(--font-body, sans-serif);
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text, #fff);
    opacity: 0.8;
    margin: 0;
    line-height: 1.6;
  }
</style>
