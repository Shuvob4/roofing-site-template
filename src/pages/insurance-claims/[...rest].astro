---
/**
 * Insurance Claims Page — Guides homeowners through the insurance claim process.
 * Uses getStaticPaths() to conditionally generate this route.
 * If module disabled: page is NOT generated at build time (no orphan URL).
 *
 * Validates: Requirements 19.1, 19.2, 19.3, 19.4, 19.5, 19.6, 19.7
 */
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const modulesEntry = await getEntry('modules', 'modules');
  const isEnabled = modulesEntry?.data?.insuranceClaims ?? false;
  if (!isEnabled) return [];
  const entries = await getCollection('insurance');
  if (entries.length === 0) return [];
  return [{ params: { rest: undefined } }];
}

const entries = await getCollection('insurance');
const steps = entries
  .map((entry) => entry.data)
  .sort((a, b) => a.stepNumber - b.stepNumber);
---

<PageLayout title="Insurance Claims" description="Step-by-step guide to navigating your roofing insurance claim process.">
  <section class="insurance-page" aria-label="Insurance claims process">
    <div class="insurance-page__header">
      <h1 class="insurance-page__title">Insurance Claims Process</h1>
      <p class="insurance-page__subtitle">
        Follow these steps to navigate your roofing insurance claim with confidence.
      </p>
    </div>
    <ol class="insurance-page__steps" role="list">
      {steps.map((step) => (
        <li class="insurance-step" aria-label={`Step ${step.stepNumber}: ${step.title}`}>
          <div class="insurance-step__number" aria-hidden="true">
            {step.icon && <span class="insurance-step__icon">{step.icon}</span>}
            <span>{step.stepNumber}</span>
          </div>
          <div class="insurance-step__content">
            <h2 class="insurance-step__title">{step.title}</h2>
            <p class="insurance-step__description">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
</PageLayout>

<style>
  .insurance-page {
    min-height: 60vh;
    padding: 3rem 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .insurance-page__header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .insurance-page__title {
    font-family: var(--font-heading, sans-serif);
    font-size: var(--font-size-display, 2.5rem);
    font-weight: 700;
    color: var(--color-text, #fff);
    margin: 0 0 0.75rem;
  }

  .insurance-page__subtitle {
    font-family: var(--font-body, sans-serif);
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text, #fff);
    opacity: 0.8;
    margin: 0;
    line-height: 1.6;
  }

  .insurance-page__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .insurance-step {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    padding: 1.5rem;
    background: color-mix(in srgb, var(--color-background, #1a1a2e) 80%, var(--color-primary, #4a90d9) 20%);
    border-radius: var(--border-radius, 0.5rem);
    border-left: 4px solid var(--color-primary, #4a90d9);
  }

  .insurance-step__number {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    height: 3rem;
    background: var(--color-primary, #4a90d9);
    color: var(--color-background, #1a1a2e);
    border-radius: 50%;
    font-family: var(--font-heading, sans-serif);
    font-size: var(--font-size-large, 1.25rem);
    font-weight: 700;
    flex-shrink: 0;
  }

  .insurance-step__icon {
    display: none;
  }

  .insurance-step__content {
    flex: 1;
  }

  .insurance-step__title {
    font-family: var(--font-heading, sans-serif);
    font-size: var(--font-size-large, 1.25rem);
    font-weight: 600;
    color: var(--color-text, #fff);
    margin: 0 0 0.5rem;
  }

  .insurance-step__description {
    font-family: var(--font-body, sans-serif);
    font-size: var(--font-size-base, 1rem);
    color: var(--color-text, #fff);
    opacity: 0.85;
    margin: 0;
    line-height: 1.6;
  }

  @media (max-width: 640px) {
    .insurance-step {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1rem;
    }
  }
</style>
